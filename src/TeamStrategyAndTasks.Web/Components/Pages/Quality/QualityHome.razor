@page "/quality"
@attribute [Authorize]

<PageTitle>Quality Engineering</PageTitle>

<MudStack Spacing="6" Class="pa-2">

    <div>
        <MudText Typo="Typo.h5" GutterBottom="true">Quality Engineering</MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            AS9100-aligned quality management — clause conformance, PFMEA, control plans, audits, and CAPA —
            in a bounded context that is intentionally separate from strategic planning.
        </MudText>
    </div>

    <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Construction" Elevation="0">
        This module is under active development and will be delivered in Phase 7.
        The planned sub-modules are shown below.
    </MudAlert>

    <MudGrid Spacing="3">

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Success" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">AS9100 Conformance</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Coming soon</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Track clause-by-clause conformance state, assign evidence owners, and maintain
                        audit-ready records with full status history.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Color="Color.Warning" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">PFMEA</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Coming soon</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Document failure modes, effects, causes, and controls with S/O/D scoring, RPN/AP
                        prioritization, recommended actions, and re-score workflow.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Control Plans</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Coming soon</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Manage process characteristics, control methods, sampling instructions, reaction plans,
                        and immutable revision history.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.FindInPage" Color="Color.Info" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Audits &amp; Findings</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Coming soon</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Plan and execute internal and external audits, record findings, assign containment,
                        and track corrective action status through to closure.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Error" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">CAPA</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Coming soon</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Root-cause workflow from containment through corrective action to effectiveness
                        verification, with action owners, due dates, and closure tracking.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" Color="Color.Secondary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1">Reports &amp; Evidence</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Coming soon</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Auditor-facing clause checklist, evidence packet export, open-risk trend reports,
                        and CAPA closure metrics — all independent from strategic exports.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>

</MudStack>
