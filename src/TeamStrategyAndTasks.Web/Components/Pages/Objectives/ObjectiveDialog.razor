@using TeamStrategyAndTasks.Core.DTOs
@using TeamStrategyAndTasks.Core.Entities
@using TeamStrategyAndTasks.Core.Enums

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Existing is null ? "New Objective" : "Edit Objective")</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="@(Existing is null ? 7 : 12)">
                <MudForm @ref="_form" @bind-IsValid="_valid">
                    <MudTextField @bind-Value="_title" Label="Title" Required="true"
                                  RequiredError="Title is required." Class="mb-3" Immediate="true" />
                    <MudTextField @bind-Value="_description" Label="Description"
                                  Lines="3" Class="mb-3" />
                    <MudTextField @bind-Value="_successMetric" Label="Success Metric" Class="mb-3" />
                    <MudTextField @bind-Value="_targetValue" Label="Target Value" Class="mb-3" />
                    <MudDatePicker @bind-Date="_targetDate" Label="Target Date" Class="mb-3" />
                    @if (Existing is not null)
                    {
                        <MudSelect T="NodeStatus" @bind-Value="_status" Label="Status" Class="mb-3">
                            @foreach (NodeStatus s in Enum.GetValues(typeof(NodeStatus)))
                            {
                                <MudSelectItem Value="s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    }
                </MudForm>
            </MudItem>
            @if (Existing is null)
            {
                <MudItem xs="12" md="5">
                    <SuggestionPanel NodeType="NodeType.Objective"
                                     Keyword="@_title"
                                     OnAdopted="HandleAdopted" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="!_valid" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Objective? Existing { get; set; }

    private MudForm _form = null!;
    private bool _valid;

    private string _title = string.Empty;
    private string? _description;
    private string? _successMetric;
    private string? _targetValue;
    private DateTime? _targetDate;
    private NodeStatus _status = NodeStatus.NotStarted;
    private IReadOnlyList<CascadeItem> _pendingCascade = [];

    protected override void OnParametersSet()
    {
        if (Existing is not null)
        {
            _title = Existing.Title;
            _description = Existing.Description;
            _successMetric = Existing.SuccessMetric;
            _targetValue = Existing.TargetValue;
            _targetDate = Existing.TargetDate?.Date;
            _status = Existing.Status;
        }
    }

    private void HandleAdopted(SuggestionAdoptedArgs args)
    {
        _title = args.Title;
        _description = args.Description;
        _pendingCascade = args.CascadeItems;
    }

    private async Task Submit()
    {
        await _form.Validate();
        if (!_valid) return;

        var targetDate = _targetDate.HasValue
            ? (DateTimeOffset?)new DateTimeOffset(_targetDate.Value, TimeSpan.Zero)
            : null;

        if (Existing is null)
        {
            MudDialog.Close(DialogResult.Ok(
                new SuggestionCreateResult<CreateObjectiveRequest>(
                    new CreateObjectiveRequest(_title, _description, _successMetric, _targetValue, targetDate),
                    _pendingCascade)));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(
                new UpdateObjectiveRequest(_title, _description, _successMetric, _targetValue, targetDate, _status)));
        }
    }

    private void Cancel() => MudDialog.Cancel();
}

