@page "/objectives/{Id:guid}"
@attribute [Authorize]
@using TeamStrategyAndTasks.Core.DTOs
@using TeamStrategyAndTasks.Core.Enums
@using TeamStrategyAndTasks.Core.Entities
@using TeamStrategyAndTasks.Core.Exceptions
@using TeamStrategyAndTasks.Core.Interfaces
@inject IObjectiveService ObjectiveService
@inject IProcessService ProcessService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager

<PageTitle>@(_objective?.Title ?? "Objective")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_objective is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3">Objective not found.</MudAlert>
    <MudButton OnClick='() => Nav.NavigateTo("/objectives")'>Back to Objectives</MudButton>
}
else
{
    <MudBreadcrumbs Items="Breadcrumbs" Class="mb-2 px-0" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">@_objective.Title</MudText>
        <MudSpacer />
        <StatusChip Status="_objective.Status" />
        <MudTooltip Text="Edit">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                           OnClick="OpenEditDialog" />
        </MudTooltip>
        <MudTooltip Text="Archive">
            <MudIconButton Icon="@Icons.Material.Filled.Archive" Color="Color.Warning"
                           OnClick="Archive" />
        </MudTooltip>
    </MudStack>

    <MudGrid>
        <!-- Details -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Details</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2">Description</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_objective.Description ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Success Metric</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_objective.SuccessMetric ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Target Value</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_objective.TargetValue ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Target Date</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_objective.TargetDate?.ToString("yyyy-MM-dd") ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Owner</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_ownerName ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Created</MudText>
                    <MudText Class="mud-text-secondary mb-3">@_objective.CreatedAt.ToString("yyyy-MM-dd")</MudText>
                    <MudText Typo="Typo.subtitle2">Last Updated</MudText>
                    <MudText Class="mud-text-secondary">@_objective.UpdatedAt.ToString("yyyy-MM-dd")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Linked Processes -->
        <MudItem xs="12" md="8">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Linked Processes</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton StartIcon="@Icons.Material.Filled.AddLink"
                                   Variant="Variant.Text" Color="Color.Primary"
                                   OnClick="OpenLinkProcessDialog">Link</MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (!_objective.ObjectiveProcesses.Any())
                    {
                        <MudText Class="mud-text-secondary">No processes linked yet.</MudText>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                            <thead>
                                <tr>
                                    <th>Process</th>
                                    <th>Status</th>
                                    <th style="width:48px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var op in _objective.ObjectiveProcesses.OrderBy(x => x.DisplayOrder).ThenBy(x => x.Process.Title))
                                {
                                    <tr>
                                        <td>
                                            <MudLink Href="@($"/processes/{op.ProcessId}")">@op.Process.Title</MudLink>
                                        </td>
                                        <td><StatusChip Status="op.Process.Status" /></td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                                           Size="Size.Small" Color="Color.Error"
                                                          
                                                           OnClick="@(() => UnlinkProcess(op.ProcessId))" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12">
            <CommentThread NodeType="NodeType.Objective" NodeId="Id" NodeOwnerId="@_objective!.OwnerId" />
        </MudItem>
        <MudItem xs="12">
            <AttachmentPanel NodeType="NodeType.Objective" NodeId="Id" />
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Objective? _objective;
    private bool _loading = true;
    private string? _ownerName;

    private List<BreadcrumbItem> Breadcrumbs =>
    [
        new("Objectives", href: "/objectives"),
        new(_objective?.Title ?? "Detail", href: null, disabled: true)
    ];

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _objective = await ObjectiveService.GetByIdAsync(Id);
            var owner = await UserManager.FindByIdAsync(_objective.OwnerId.ToString());
            _ownerName = owner?.DisplayName;
        }
        catch (NotFoundException) { _objective = null; }
        finally { _loading = false; }
    }

    private async Task OpenLinkProcessDialog()
    {
        var all = await ProcessService.GetAllAsync();
        var linkedIds = _objective!.ObjectiveProcesses.Select(op => op.ProcessId).ToHashSet();
        var available = all
            .Where(p => !linkedIds.Contains(p.Id))
            .Select(p => new LinkableItem(p.Id, p.Title, p.Status.ToString()))
            .ToList();

        var parameters = new DialogParameters<LinkPickerDialog>
        {
            { d => d.Title, "Link a Process" },
            { d => d.Items, available }
        };
        var dialog = await DialogService.ShowAsync<LinkPickerDialog>("Link Process", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: Guid pid })
        {
            await ObjectiveService.LinkProcessAsync(Id, pid);
            Snackbar.Add("Process linked.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task UnlinkProcess(Guid processId)
    {
        await ObjectiveService.UnlinkProcessAsync(Id, processId);
        Snackbar.Add("Process unlinked.", Severity.Info);
        await LoadAsync();
    }

    private async Task OpenEditDialog()
    {
        var parameters = new DialogParameters<ObjectiveDialog> { { d => d.Existing, _objective } };
        var dialog = await DialogService.ShowAsync<ObjectiveDialog>("Edit Objective", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: UpdateObjectiveRequest req })
        {
            await ObjectiveService.UpdateAsync(Id, req);
            Snackbar.Add("Objective updated.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task Archive()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { d => d.Title, "Archive Objective" },
            { d => d.Message, $"Archive \"{_objective!.Title}\"?" },
            { d => d.ConfirmLabel, "Archive" }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Archive", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await ObjectiveService.ArchiveAsync(Id);
            Nav.NavigateTo("/objectives");
        }
    }
}
