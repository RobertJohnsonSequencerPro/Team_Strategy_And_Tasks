@page "/initiatives/{Id:guid}"
@attribute [Authorize]
@using TeamStrategyAndTasks.Core.Entities
@using TeamStrategyAndTasks.Core.Enums
@using TeamStrategyAndTasks.Core.Exceptions
@using TeamStrategyAndTasks.Core.Interfaces
@inject IInitiativeService InitiativeService
@inject NavigationManager Nav

<PageTitle>@(_initiative?.Title ?? "Initiative")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_initiative is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3">@(_loadError ?? "Initiative not found.")</MudAlert>
    <MudButton OnClick='() => Nav.NavigateTo("/initiatives")'>Back to Initiatives</MudButton>
}
else
{
    <MudBreadcrumbs Items="Breadcrumbs" Class="mb-2 px-0" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">@_initiative.Title</MudText>
        <MudSpacer />
        <StatusChip Status="_initiative.Status" />
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Details</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2">Description</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_initiative.Description ?? "—")</MudText>

                    <MudText Typo="Typo.subtitle2">Target Date</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_initiative.TargetDate?.ToString("yyyy-MM-dd") ?? "—")</MudText>

                    <MudText Typo="Typo.subtitle2">Created</MudText>
                    <MudText Class="mud-text-secondary mb-3">@_initiative.CreatedAt.ToString("yyyy-MM-dd")</MudText>

                    <MudText Typo="Typo.subtitle2">Last Updated</MudText>
                    <MudText Class="mud-text-secondary">@_initiative.UpdatedAt.ToString("yyyy-MM-dd")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudStack Spacing="4">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Parent Processes</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!_initiative.ProcessInitiatives.Any(pi => pi.Process is not null))
                        {
                            <MudText Class="mud-text-secondary">Not linked to any processes.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <thead>
                                    <tr>
                                        <th>Process</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pi in _initiative.ProcessInitiatives.Where(x => x.Process is not null).OrderBy(x => x.Process!.Title))
                                    {
                                        <tr>
                                            <td><MudLink Href="@($"/processes/{pi.ProcessId}")">@pi.Process!.Title</MudLink></td>
                                            <td><StatusChip Status="pi.Process!.Status" /></td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudCardContent>
                </MudCard>

                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Linked Tasks</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!_initiative.InitiativeWorkTasks.Any(it => it.WorkTask is not null))
                        {
                            <MudText Class="mud-text-secondary">No tasks linked yet.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var it in _initiative.InitiativeWorkTasks.Where(x => x.WorkTask is not null).OrderBy(x => x.DisplayOrder).ThenBy(x => x.WorkTask!.Title))
                                    {
                                        <tr>
                                            <td><MudLink Href="@($"/tasks/{it.WorkTaskId}")">@it.WorkTask!.Title</MudLink></td>
                                            <td><StatusChip Status="it.WorkTask!.Status" /></td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudCardContent>
                </MudCard>

                <DecisionPanel NodeType="NodeType.Initiative" NodeId="Id" />
            </MudStack>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Initiative? _initiative;
    private bool _loading = true;
    private string? _loadError;
    private Guid _loadedId;

    private List<BreadcrumbItem> Breadcrumbs =>
    [
        new("Strategy", href: "/strategy"),
        new(_initiative?.Title ?? "Detail", href: null, disabled: true)
    ];

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            _initiative = await WithTimeout(InitiativeService.GetByIdAsync(Id), TimeSpan.FromSeconds(15), "initiative query");
            _initiative.ProcessInitiatives = _initiative.ProcessInitiatives.Where(pi => pi.Process is not null).ToList();
            _initiative.InitiativeWorkTasks = _initiative.InitiativeWorkTasks.Where(iw => iw.WorkTask is not null).ToList();
        }
        catch (NotFoundException)
        {
            _initiative = null;
            _loadError = "Initiative not found.";
        }
        catch (TimeoutException ex)
        {
            _initiative = null;
            _loadError = ex.Message;
            Console.Error.WriteLine($"Timeout loading initiative {Id}: {ex}");
        }
        catch (Exception ex)
        {
            _initiative = null;
            _loadError = "Unable to load initiative details.";
            Console.Error.WriteLine($"Failed loading initiative {Id}: {ex}");
        }
        finally
        {
            _loading = false;
        }
    }

    private static async Task<T> WithTimeout<T>(Task<T> task, TimeSpan timeout, string operation)
    {
        var completed = await Task.WhenAny(task, Task.Delay(timeout));
        if (completed == task)
            return await task;

        throw new TimeoutException($"{operation} exceeded {timeout.TotalSeconds:0} seconds.");
    }
}
