@page "/initiatives/{Id:guid}"
@attribute [Authorize]
@using TeamStrategyAndTasks.Core.DTOs
@using TeamStrategyAndTasks.Core.Enums
@using TeamStrategyAndTasks.Core.Entities
@using TeamStrategyAndTasks.Core.Exceptions
@using TeamStrategyAndTasks.Core.Interfaces
@inject IInitiativeService InitiativeService
@inject IProcessService ProcessService
@inject ITaskService TaskService
@inject IDialogService DialogService
@inject ITeamService TeamService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<PageTitle>@(_initiative?.Title ?? "Initiative")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_initiative is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3">Initiative not found.</MudAlert>
    <MudButton OnClick='() => Nav.NavigateTo("/initiatives")'>Back to Initiatives</MudButton>
}
else
{
    <MudBreadcrumbs Items="Breadcrumbs" Class="mb-2 px-0" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">@_initiative.Title</MudText>
        <MudSpacer />
        <StatusChip Status="_initiative.Status" />
        <MudTooltip Text="Edit">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                           OnClick="OpenEditDialog" />
        </MudTooltip>
        <MudTooltip Text="Archive">
            <MudIconButton Icon="@Icons.Material.Filled.Archive" Color="Color.Warning"
                           OnClick="Archive" />
        </MudTooltip>
    </MudStack>

    <MudGrid>
        <!-- Details -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Details</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2">Description</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_initiative.Description ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Target Date</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_initiative.TargetDate?.ToString("yyyy-MM-dd") ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Owner</MudText>
                    <MudText Class="mud-text-secondary mb-3">@(_ownerName ?? "—")</MudText>
                    <MudText Typo="Typo.subtitle2">Created</MudText>
                    <MudText Class="mud-text-secondary mb-3">@_initiative.CreatedAt.ToString("yyyy-MM-dd")</MudText>
                    <MudText Typo="Typo.subtitle2">Last Updated</MudText>
                    <MudText Class="mud-text-secondary">@_initiative.UpdatedAt.ToString("yyyy-MM-dd")</MudText>
                    <MudText Typo="Typo.subtitle2" Class="mt-3">Responsible Team</MudText>
                    <div class="mb-1">
                        @if (_allTeams.FirstOrDefault(t => t.Id == _selectedTeamId) is { } currentTeam)
                        {
                            <div class="mb-1"><TeamChip Team="currentTeam" /></div>
                        }
                        <MudSelect T="Guid?" Value="_selectedTeamId" ValueChanged="HandleTeamChanged"
                                   Dense="true" Margin="Margin.Dense" Clearable="true"
                                   Placeholder="No team assigned">
                            @foreach (var t in _allTeams)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)t.Id)">@t.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Parent Processes + Child Tasks -->
        <MudItem xs="12" md="8">
            <MudStack Spacing="4">
                <!-- Parent Processes -->
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Parent Processes</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton StartIcon="@Icons.Material.Filled.AddLink"
                                       Variant="Variant.Text" Color="Color.Primary"
                                       OnClick="OpenLinkProcessDialog">Link</MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!_initiative.ProcessInitiatives.Any())
                        {
                            <MudText Class="mud-text-secondary">Not linked to any processes.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <thead>
                                    <tr>
                                        <th>Process</th>
                                        <th>Status</th>
                                        <th style="width:48px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pi in _initiative.ProcessInitiatives.OrderBy(x => x.Process.Title))
                                    {
                                        <tr>
                                            <td>
                                                <MudLink Href="@($"/processes/{pi.ProcessId}")">@pi.Process.Title</MudLink>
                                            </td>
                                            <td><StatusChip Status="pi.Process.Status" /></td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                                               Size="Size.Small" Color="Color.Error"
                                                              
                                                               OnClick="@(() => UnlinkProcess(pi.ProcessId))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudCardContent>
                </MudCard>

                <!-- Child Tasks -->
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Linked Tasks</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudButton StartIcon="@Icons.Material.Filled.AddLink"
                                       Variant="Variant.Text" Color="Color.Primary"
                                       OnClick="OpenLinkTaskDialog">Link</MudButton>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!_initiative.InitiativeWorkTasks.Any())
                        {
                            <MudText Class="mud-text-secondary">No tasks linked yet.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>Status</th>
                                        <th style="width:48px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var it in _initiative.InitiativeWorkTasks.OrderBy(x => x.DisplayOrder).ThenBy(x => x.WorkTask.Title))
                                    {
                                        <tr>
                                            <td>
                                                <MudLink Href="@($"/tasks/{it.WorkTaskId}")">@it.WorkTask.Title</MudLink>
                                            </td>
                                            <td><StatusChip Status="it.WorkTask.Status" /></td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                                               Size="Size.Small" Color="Color.Error"
                                                              
                                                               OnClick="@(() => UnlinkTask(it.WorkTaskId))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudCardContent>
                </MudCard>
            </MudStack>
        </MudItem>
        <MudItem xs="12">
            <CommentThread NodeType="NodeType.Initiative" NodeId="Id" NodeOwnerId="@_initiative!.OwnerId" />
        </MudItem>
        <MudItem xs="12">
            <MilestonePanel InitiativeId="Id" CurrentUserId="@_currentUserId" />
        </MudItem>
        <MudItem xs="12">
            <RiskPanel NodeType="NodeType.Initiative" NodeId="Id" CurrentUserId="@_currentUserId" />
        </MudItem>
        <MudItem xs="12">
            <DependencyPanel NodeType="NodeType.Initiative"
                             NodeId="Id"
                             NodeTitle="@(_initiative?.Title ?? string.Empty)"
                             CurrentUserId="@_currentUserId" />
        </MudItem>
        <MudItem xs="12">
            <AttachmentPanel NodeType="NodeType.Initiative" NodeId="Id" />
        </MudItem>
        <MudItem xs="12">
            <AuditLogPanel NodeType="NodeType.Initiative" NodeId="Id"
                           CurrentUserId="@_currentUserId"
                           CanRevert="@_canRevert" />
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private Initiative? _initiative;
    private bool _loading = true;
    private string? _ownerName;
    private Guid _currentUserId;
    private bool _canRevert;
    private Guid _loadedId;
    private IReadOnlyList<Team> _allTeams = [];
    private Guid? _selectedTeamId;

    private List<BreadcrumbItem> Breadcrumbs =>
    [
        new("Strategy", href: "/strategy"),
        new(_initiative?.Title ?? "Detail", href: null, disabled: true)
    ];

    protected override async Task OnParametersSetAsync()
    {
        if (Id == _loadedId) return;
        _loadedId = Id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _initiative = await InitiativeService.GetByIdAsync(Id);
            var owner = await UserManager.FindByIdAsync(_initiative.OwnerId.ToString());
            _ownerName = owner?.DisplayName;
            _allTeams = await TeamService.GetAllAsync();
            _selectedTeamId = _initiative.TeamId;
            if (Guid.TryParse(authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var uid))
                _currentUserId = uid;
            _canRevert = authState.User.IsInRole("Administrator") || _initiative.OwnerId == _currentUserId;
        }
        catch (NotFoundException) { _initiative = null; }
        finally { _loading = false; }
    }

    private async Task HandleTeamChanged(Guid? newTeamId)
    {
        _selectedTeamId = newTeamId;
        await InitiativeService.SetResponsibleTeamAsync(Id, newTeamId, _currentUserId);
        await LoadAsync();
    }

    private async Task OpenLinkProcessDialog()
    {
        var all = await ProcessService.GetAllAsync();
        var linkedIds = _initiative!.ProcessInitiatives.Select(pi => pi.ProcessId).ToHashSet();
        var available = all
            .Where(p => !linkedIds.Contains(p.Id))
            .Select(p => new LinkableItem(p.Id, p.Title, p.Status.ToString()))
            .ToList();

        var parameters = new DialogParameters<LinkPickerDialog>
        {
            { d => d.Title, "Link to a Process" },
            { d => d.Items, available }
        };
        var dialog = await DialogService.ShowAsync<LinkPickerDialog>("Link Process", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: Guid pid })
        {
            await ProcessService.LinkInitiativeAsync(pid, Id);
            Snackbar.Add("Linked to process.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task UnlinkProcess(Guid processId)
    {
        await ProcessService.UnlinkInitiativeAsync(processId, Id);
        Snackbar.Add("Unlinked from process.", Severity.Info);
        await LoadAsync();
    }

    private async Task OpenLinkTaskDialog()
    {
        var all = await TaskService.GetAllAsync();
        var linkedIds = _initiative!.InitiativeWorkTasks.Select(it => it.WorkTaskId).ToHashSet();
        var available = all
            .Where(t => !linkedIds.Contains(t.Id))
            .Select(t => new LinkableItem(t.Id, t.Title, t.Status.ToString()))
            .ToList();

        var parameters = new DialogParameters<LinkPickerDialog>
        {
            { d => d.Title, "Link a Task" },
            { d => d.Items, available }
        };
        var dialog = await DialogService.ShowAsync<LinkPickerDialog>("Link Task", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: Guid tid })
        {
            await InitiativeService.LinkTaskAsync(Id, tid);
            Snackbar.Add("Task linked.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task UnlinkTask(Guid taskId)
    {
        await InitiativeService.UnlinkTaskAsync(Id, taskId);
        Snackbar.Add("Task unlinked.", Severity.Info);
        await LoadAsync();
    }

    private async Task OpenEditDialog()
    {
        var parameters = new DialogParameters<InitiativeDialog> { { d => d.Existing, _initiative } };
        var dialog = await DialogService.ShowAsync<InitiativeDialog>("Edit Initiative", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: UpdateInitiativeRequest req })
        {
            await InitiativeService.UpdateAsync(Id, req, _currentUserId);
            Snackbar.Add("Initiative updated.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task Archive()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { d => d.Title, "Archive Initiative" },
            { d => d.Message, $"Archive \"{_initiative!.Title}\"?" },
            { d => d.ConfirmLabel, "Archive" }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Archive", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await InitiativeService.ArchiveAsync(Id);
            Nav.NavigateTo("/initiatives");
        }
    }
}
