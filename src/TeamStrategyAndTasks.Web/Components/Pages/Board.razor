@page "/board"
@attribute [Authorize]
@using System.Security.Claims
@using TeamStrategyAndTasks.Core.DTOs
@using TeamStrategyAndTasks.Core.Entities
@using TeamStrategyAndTasks.Core.Enums
@using TeamStrategyAndTasks.Core.Interfaces
@using TeamStrategyAndTasks.Web.Components.Pages.Tasks
@inject ITaskService TaskService
@inject IInitiativeService InitiativeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Board</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Board</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
               Color="Color.Primary" OnClick="OpenCreateDialog">New Task</MudButton>
</MudStack>

@* Filter bar *@
<MudPaper Elevation="2" Class="pa-3 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
        <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Color="Color.Primary" />
        <MudText Typo="Typo.subtitle2" Style="white-space:nowrap">Initiative</MudText>
        <MudSelect T="Guid?" @bind-Value="_initiativeId" Placeholder="All initiatives"
                   Clearable="true" Dense="true" Margin="Margin.Dense" Style="min-width:260px"
                   ToStringFunc="@(id => id.HasValue ? (_initiatives.FirstOrDefault(i => i.Id == id.Value)?.Title ?? "") : "")">
            @foreach (var init in _initiatives)
            {
                <MudSelectItem T="Guid?" Value="init.Id">@init.Title</MudSelectItem>
            }
        </MudSelect>

        <MudDivider Vertical="true" FlexItem="true" />

        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Default" />
        <MudText Typo="Typo.subtitle2" Style="white-space:nowrap">Assignee</MudText>
        <MudSelect T="Guid?" @bind-Value="_assigneeId" Placeholder="Anyone"
                   Clearable="true" Dense="true" Margin="Margin.Dense" Style="min-width:220px"
                   ToStringFunc="@(id => id.HasValue ? (_assigneeNames.GetValueOrDefault(id.Value, id.Value.ToString()[..8]) ) : "")">
            @foreach (var (id, name) in _assigneeNames)
            {
                <MudSelectItem T="Guid?" Value="id">@name</MudSelectItem>
            }
        </MudSelect>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @* Kanban columns *@
    <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:12px; align-items:start; overflow-x:auto">
        @foreach (var col in Columns)
        {
            var cards = FilteredTasks.Where(t => t.Status == col.Status).OrderBy(t => t.TargetDate).ToList();
            <div style="min-width:200px">
                @* Column header *@
                <div style="display:flex; align-items:center; gap:6px; margin-bottom:8px; padding:6px 8px;
                            background:@col.HeaderBg; border-radius:6px">
                    <MudIcon Icon="@col.Icon" Size="Size.Small" Style="@($"color:{col.Color}")" />
                    <span style="font-weight:600; font-size:13px; color:@col.Color">@col.Label</span>
                    <MudBadge Content="@cards.Count" Color="Color.Default" Overlap="false"
                              Style="margin-left:auto" BadgeStyle="font-size:10px" />
                </div>

                @* Cards *@
                <MudStack Spacing="2">
                    @foreach (var task in cards)
                    {
                        var captured = task;
                        <MudPaper Elevation="2" Class="pa-3"
                                  Style="@($"border-left:4px solid {col.Color}; cursor:pointer")"
                                  @onclick="@(() => OpenEditDialog(captured))">
                            <MudText Typo="Typo.body2" Style="font-weight:500; margin-bottom:4px">
                                @task.Title
                            </MudText>
                            @if (task.TargetDate.HasValue)
                            {
                                var overdue = task.TargetDate.Value < DateTimeOffset.UtcNow
                                              && task.Status is not NodeStatus.Done and not NodeStatus.Complete;
                                <MudText Typo="Typo.caption"
                                         Style="@($"color:{(overdue ? "#E53935" : "#757575")}")">
                                    @(overdue ? "⚠ " : "")@task.TargetDate.Value.ToString("MMM d")
                                </MudText>
                            }
                            @if (task.EstimatedEffort.HasValue)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @task.EstimatedEffort h est.
                                </MudText>
                            }
                            <div style="display:flex; gap:4px; margin-top:6px; flex-wrap:wrap">
                                @foreach (var iwt in task.InitiativeWorkTasks.Take(2))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="Color.Secondary" Style="font-size:10px; height:18px">
                                        @(iwt.Initiative?.Title is { Length: > 18 } t ? t[..15] + "…" : iwt.Initiative?.Title)
                                    </MudChip>
                                }
                                @if (task.InitiativeWorkTasks.Count > 2)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="Color.Default" Style="font-size:10px; height:18px">
                                        +@(task.InitiativeWorkTasks.Count - 2)
                                    </MudChip>
                                }
                            </div>
                            @* Quick action buttons *@
                            <div style="display:flex; gap:2px; margin-top:4px; justify-content:flex-end"
                                 @onclick:stopPropagation="true">
                                @if (task.Status != NodeStatus.Done && task.Status != NodeStatus.Complete)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircleOutline"
                                                   Size="Size.Small" Color="Color.Success"
                                                   Title="Mark Done"
                                                   OnClick="@(() => MarkDone(captured))" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Archive"
                                               Size="Size.Small" Color="Color.Warning"
                                               Title="Archive"
                                               OnClick="@(() => Archive(captured))" />
                            </div>
                        </MudPaper>
                    }

                    @if (cards.Count == 0)
                    {
                        <div style="border:2px dashed #e0e0e0; border-radius:6px; padding:16px;
                                    text-align:center; color:#9e9e9e; font-size:12px">
                            No tasks
                        </div>
                    }
                </MudStack>
            </div>
        }
    </div>
}

@code {
    private record KanbanColumn(NodeStatus Status, string Label, string Color, string HeaderBg, string Icon);

    private static readonly KanbanColumn[] Columns =
    [
        new(NodeStatus.NotStarted, "Not Started", "#9e9e9e", "#f5f5f5",  Icons.Material.Filled.RadioButtonUnchecked),
        new(NodeStatus.InProgress, "In Progress", "#AB47BC", "#f3e5f5",  Icons.Material.Filled.Pending),
        new(NodeStatus.Blocked,    "Blocked",     "#E53935", "#ffebee",  Icons.Material.Filled.Block),
        new(NodeStatus.Done,       "Done",        "#388E3C", "#e8f5e9",  Icons.Material.Filled.CheckCircle),
        new(NodeStatus.Cancelled,  "Cancelled",   "#757575", "#f5f5f5",  Icons.Material.Filled.Cancel),
    ];

    private IReadOnlyList<WorkTask>  _tasks       = [];
    private IReadOnlyList<Initiative> _initiatives = [];
    private Dictionary<Guid, string>  _assigneeNames = new();
    private string _search     = string.Empty;
    private bool   _loading    = true;
    private Guid   _currentUserId;
    private Guid?  _initiativeId;
    private Guid?  _assigneeId;

    private IEnumerable<WorkTask> FilteredTasks
    {
        get
        {
            var q = _tasks.AsEnumerable();
            if (_initiativeId.HasValue)
                q = q.Where(t => t.InitiativeWorkTasks.Any(iwt => iwt.InitiativeId == _initiativeId.Value));
            if (_assigneeId.HasValue)
                q = q.Where(t => t.AssigneeId == _assigneeId.Value);
            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (Guid.TryParse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id))
            _currentUserId = id;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _tasks       = await TaskService.GetAllAsync();
        _initiatives = await InitiativeService.GetAllAsync();

        // Collect distinct assignees from loaded tasks (names displayed as truncated IDs;
        // a future enhancement can inject UserManager here for display names)
        _assigneeNames = _tasks
            .Where(t => t.AssigneeId.HasValue)
            .Select(t => t.AssigneeId!.Value)
            .Distinct()
            .ToDictionary(gid => gid, gid => gid.ToString()[..8] + "…");

        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<TaskDialog>("New Task",
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: SuggestionCreateResult<CreateTaskRequest> r })
        {
            await TaskService.CreateAsync(r.Request, _currentUserId);
            Snackbar.Add("Task created.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task OpenEditDialog(WorkTask task)
    {
        var parameters = new DialogParameters<TaskDialog> { { d => d.Existing, task } };
        var dialog = await DialogService.ShowAsync<TaskDialog>("Edit Task", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: UpdateTaskRequest req })
        {
            await TaskService.UpdateAsync(task.Id, req, _currentUserId);
            Snackbar.Add("Task updated.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task MarkDone(WorkTask task)
    {
        await TaskService.CompleteAsync(task.Id);
        Snackbar.Add($"\"{task.Title}\" marked done.", Severity.Success);
        await LoadAsync();
    }

    private async Task Archive(WorkTask task)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { d => d.Title,        "Archive Task" },
            { d => d.Message,      $"Archive \"{task.Title}\"?" },
            { d => d.ConfirmLabel, "Archive" },
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Archive", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await TaskService.ArchiveAsync(task.Id);
            Snackbar.Add("Task archived.", Severity.Info);
            await LoadAsync();
        }
    }
}
