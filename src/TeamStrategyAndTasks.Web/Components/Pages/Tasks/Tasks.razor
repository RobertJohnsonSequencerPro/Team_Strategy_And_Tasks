@page "/tasks"
@attribute [Authorize]
@using System.Security.Claims
@using TeamStrategyAndTasks.Core.DTOs
@using TeamStrategyAndTasks.Core.Entities
@using TeamStrategyAndTasks.Core.Interfaces
@inject ITaskService TaskService
@inject IInitiativeService InitiativeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject ISavedFilterService SavedFilterService
@using System.Text.Json

<PageTitle>Tasks</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Tasks</MudText>
    <MudSpacer />
    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
               Color="Color.Primary" OnClick="OpenCreateDialog">New Task</MudButton>
</MudStack>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Color="Color.Primary" />
        <MudText Typo="Typo.subtitle1" Style="white-space:nowrap; font-weight:500">Initiative</MudText>
        <MudSelect T="Guid?" @bind-Value="_selectedInitiativeId" Placeholder="All initiatives"
                   Clearable="true" Dense="true" Margin="Margin.Dense" Style="min-width:320px"
                   ToStringFunc="@(id => id.HasValue ? (_initiatives.FirstOrDefault(i => i.Id == id.Value)?.Title ?? "") : "")">
            @foreach (var init in _initiatives)
            {
                <MudSelectItem T="Guid?" Value="init.Id">@init.Title</MudSelectItem>
            }
        </MudSelect>
        @if (_selectedInitiativeId.HasValue)
        {
            var sel = _initiatives.FirstOrDefault(i => i.Id == _selectedInitiativeId.Value);
            if (sel is not null)
            {
                <StatusChip Status="sel.Status" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Tasks created here will be linked to this initiative.
                </MudText>
            }
        }
    </MudStack>
</MudPaper>

<SavedFilterPanel PageKey="tasks" UserId="_currentUserId"
                  CurrentFilterJson="@FilterJson" OnFilterLoaded="ApplyFilter" />

@{
    var orphanTasks = _tasks.Where(t => !t.InitiativeWorkTasks.Any()).ToList();
}
@if (orphanTasks.Count > 0)
{
    <MudExpansionPanels Class="mb-4" Elevation="2">
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.LinkOff" Color="Color.Warning" Size="Size.Small" />
                    <MudText Style="font-weight:500">
                        @orphanTasks.Count unlinked task@(orphanTasks.Count == 1 ? "" : "s") — not connected to any initiative
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Class="pa-2" Spacing="1">
                    @foreach (var t in orphanTasks)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="py-1">
                            <MudLink Href="@($"/tasks/{t.Id}")">@t.Title</MudLink>
                            <StatusChip Status="t.Status" />
                            <MudSpacer />
                            @if (_selectedInitiativeId.HasValue)
                            {
                                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Link"
                                           Variant="Variant.Text" Color="Color.Primary"
                                           OnClick="@(() => LinkOrphanTask(t))">
                                    Link to @(_initiatives.FirstOrDefault(i => i.Id == _selectedInitiativeId.Value)?.Title ?? "")
                                </MudButton>
                            }
                        </MudStack>
                    }
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>
}

<MudDataGrid T="WorkTask" Items="FilteredTasks" Filterable="false" SortMode="SortMode.Single"
             QuickFilter="QuickFilter" Dense="true" Hover="true" Elevation="2">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="_search" Placeholder="Search..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Class="mt-0" />
    </ToolBarContent>
    <Columns>
        <TemplateColumn Title="Title" SortBy="t => t.Title">
            <CellTemplate>
                <MudLink Href="@($"/tasks/{context.Item.Id}")">@context.Item.Title</MudLink>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Status" SortBy="t => t.Status">
            <CellTemplate>
                <StatusChip Status="context.Item.Status" />
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="t => t.EstimatedEffort" Title="Est. (h)" />
        <PropertyColumn Property="t => t.TargetDate" Title="Target Date" Format="yyyy-MM-dd" />
        <TemplateColumn Title="" CellStyle="width:130px">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context.Item))" />
                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                               Color="Color.Success"
                               OnClick="@(() => MarkDone(context.Item))" />
                <MudIconButton Icon="@Icons.Material.Filled.Archive" Size="Size.Small"
                               Color="Color.Warning" OnClick="@(() => Archive(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent>
        <MudText Class="mud-text-secondary pa-4">
            @(_selectedInitiativeId.HasValue
                ? "No tasks are linked to this initiative yet. Create one with the button above."
                : "Select an initiative above to view or create its tasks.")
        </MudText>
    </NoRecordsContent>
</MudDataGrid>

@code {
    private IReadOnlyList<WorkTask> _tasks = [];
    private IReadOnlyList<Initiative> _initiatives = [];
    private string _search = string.Empty;
    private Guid _currentUserId = Guid.Empty;
    private Guid? _selectedInitiativeId;

    private IEnumerable<WorkTask> FilteredTasks =>
        _selectedInitiativeId.HasValue
            ? _tasks.Where(t => t.InitiativeWorkTasks.Any(iwt => iwt.InitiativeId == _selectedInitiativeId.Value))
            : [];

    private string FilterJson =>
        JsonSerializer.Serialize(new { parentId = _selectedInitiativeId?.ToString() ?? string.Empty, search = _search });

    private void ApplyFilter(string json)
    {
        try
        {
            var d = JsonSerializer.Deserialize<Dictionary<string, string?>>(json);
            if (d is null) return;
            _search = d.GetValueOrDefault("search") ?? string.Empty;
            var parentIdStr = d.GetValueOrDefault("parentId");
            _selectedInitiativeId = Guid.TryParse(parentIdStr, out var g) ? g : null;
        }
        catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        await LoadAsync();
        if (Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id))
            _currentUserId = id;
    }

    private async Task LoadAsync()
    {
        _tasks = await TaskService.GetAllAsync();
        _initiatives = await InitiativeService.GetAllAsync();
    }

    private Func<WorkTask, bool> QuickFilter => t =>
        string.IsNullOrWhiteSpace(_search) ||
        t.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        (t.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<TaskDialog>("New Task",
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: SuggestionCreateResult<CreateTaskRequest> r })
        {
            var task = await TaskService.CreateAsync(r.Request, _currentUserId);

            if (_selectedInitiativeId.HasValue)
                await InitiativeService.LinkTaskAsync(_selectedInitiativeId.Value, task.Id);

            Snackbar.Add("Task created.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task OpenEditDialog(WorkTask task)
    {
        var parameters = new DialogParameters<TaskDialog> { { d => d.Existing, task } };
        var dialog = await DialogService.ShowAsync<TaskDialog>("Edit Task", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: UpdateTaskRequest req })
        {
            await TaskService.UpdateAsync(task.Id, req, _currentUserId);
            Snackbar.Add("Task updated.", Severity.Success);
            await LoadAsync();
        }
    }

    private async Task MarkDone(WorkTask task)
    {
        await TaskService.CompleteAsync(task.Id);
        Snackbar.Add($"\"{task.Title}\" marked done.", Severity.Success);
        await LoadAsync();
    }

    private async Task Archive(WorkTask task)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { d => d.Title, "Archive Task" },
            { d => d.Message, $"Archive \"{task.Title}\"?" },
            { d => d.ConfirmLabel, "Archive" }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Archive", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await TaskService.ArchiveAsync(task.Id);
            Snackbar.Add("Task archived.", Severity.Info);
            await LoadAsync();
        }
    }

    private async Task LinkOrphanTask(WorkTask task)
    {
        if (!_selectedInitiativeId.HasValue) return;
        await InitiativeService.LinkTaskAsync(_selectedInitiativeId.Value, task.Id);
        Snackbar.Add($"\"{task.Title}\" linked to initiative.", Severity.Success);
        await LoadAsync();
    }
}
