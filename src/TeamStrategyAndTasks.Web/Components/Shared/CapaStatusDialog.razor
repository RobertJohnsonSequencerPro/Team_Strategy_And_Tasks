@using TeamStrategyAndTasks.Core.DTOs
@using TeamStrategyAndTasks.Core.Enums

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Advance CAPA Status</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3">
            Current status: <strong>@StatusLabel(Case!.Status)</strong>
        </MudText>
        <MudText>
            Advance to: <strong>@StatusLabel(NextStatus(Case!.Status))</strong>
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Confirm</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CapaCaseDto? Case { get; set; }

    void Cancel() => MudDialog.Cancel();

    void Submit() => MudDialog.Close(
        DialogResult.Ok(new TransitionCapaStatusRequest(NextStatus(Case!.Status))));

    static CapaCaseStatus NextStatus(CapaCaseStatus current) => current switch
    {
        CapaCaseStatus.Open                      => CapaCaseStatus.Containment,
        CapaCaseStatus.Containment               => CapaCaseStatus.RootCauseAnalysis,
        CapaCaseStatus.RootCauseAnalysis         => CapaCaseStatus.CorrectiveAction,
        CapaCaseStatus.CorrectiveAction          => CapaCaseStatus.EffectivenessVerification,
        CapaCaseStatus.EffectivenessVerification => CapaCaseStatus.Closed,
        _                                        => CapaCaseStatus.Closed
    };

    static string StatusLabel(CapaCaseStatus s) => s switch
    {
        CapaCaseStatus.RootCauseAnalysis         => "Root Cause Analysis",
        CapaCaseStatus.CorrectiveAction          => "Corrective Action",
        CapaCaseStatus.EffectivenessVerification => "Effectiveness Verification",
        _                                        => s.ToString()
    };
}
